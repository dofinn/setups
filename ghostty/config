font-family = "Hack Nerd Font"
font-size = 18

macos-option-as-alt = true

keybind = shift+ctrl+k=goto_split:top
keybind = shift+ctrl+j=goto_split:bottom
keybind = shift+ctrl+l=goto_split:right
keybind = shift+ctrl+h=goto_split:left

keybind = shift+super+h=previous_tab
keybind = shift+super+l=next_tab

auto-update-channel = tip

keybind = shift+enter=text:\x1b\r

keybind = ctrl+k=scroll_page_lines:-5
keybind = ctrl+j=scroll_page_lines:5
