#!/usr/bin/env bash

# Switch between existing sessions via fzf
# To create a new named session: tmux new -s <name>

selected=$(tmux list-sessions -F "#{session_name}" 2>/dev/null | fzf)

if [[ -z $selected ]]; then
    exit 0
fi

if [[ -z $TMUX ]]; then
    tmux attach -t "$selected"
else
    tmux switch-client -t "$selected"
fi
